# ElevenLabs — premium voiceover tier (default for client demos).
# Restricted read/synthesis key used by createElevenLabsVoiceover.
ELEVENLABS_API_KEY=
# Write-capable key for pronunciation-dictionary sync. Server-side admin use
# only; keep it out of any synthesis path. Reserved for future dictionary sync.
ELEVENLABS_ADMIN_API_KEY=

# Deepgram — cheap/fast test tier (Aura). Reads more synthetic; not for demos.
DEEPGRAM_API_KEY=
